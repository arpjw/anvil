{
  "name": "anvil-agent",
  "version": "1.0.0",
  "description": "A terminal-based AI coding agent",
  "type": "module",
  "bin": {
    "anvil": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc --outDir dist && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@types/figlet": "^1.7.0",
    "@types/micromatch": "^4.0.10",
    "@types/react": "^19.2.17",
    "chalk": "^5.6.2",
    "diff": "^9.0.0",
    "execa": "^9.4.0",
    "figlet": "^1.11.0",
    "ink": "^6.8.0",
    "micromatch": "^4.0.8",
    "openai": "^4.68.0",
    "react": "^19.2.7",
    "simple-git": "^3.36.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "typescript-language-server": "^5.3.0"
  }
}
